# Dockerfile de Desarrollo - Hot Reload
FROM node:22-alpine

# Instalar dependencias del sistema necesarias para sqlite3 y otras
RUN apk add --no-cache \
    python3 \
    make \
    g++ \
    git \
    bash

# Crear directorio de trabajo
WORKDIR /app

# Instalar nodemon globalmente para hot reload
RUN npm install -g nodemon ts-node typescript

# Copiar archivos de dependencias primero (para caché de Docker)
COPY package*.json ./

# Instalar dependencias (esto se cachea si no cambian los package.json)
RUN npm install

# Copiar configuración de TypeScript
COPY tsconfig.json ./

# El código fuente se montará como volumen (hot reload)
# No copiamos src/ aquí para permitir el volumen

# Puerto para el backend API
EXPOSE 3000

# Script de entrada que espera el volumen y ejecuta
COPY docker-entrypoint-dev.sh /usr/local/bin/
RUN chmod +x /usr/local/bin/docker-entrypoint-dev.sh

ENTRYPOINT ["docker-entrypoint-dev.sh"]
CMD ["npm", "run", "dev"]
